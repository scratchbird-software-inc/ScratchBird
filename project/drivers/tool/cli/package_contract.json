      "C++ driver handles transport and protocol binding",
      "server revalidates authentication, authorization, SBLR, UUID, cache, schema, and transaction claims",
      "MGA transaction finality remains engine-owned"
    ],
    "lane_specific_proof": [
      "cli_auth_bootstrap_tests",
      "cli_txn_exec_parity_tests",
      "cli_metadata_shaping_tests",
      "cli_res_lifecycle_tests",
      "cli_conformance_assertion_tests",
      "cli_package_contract_smoke"
    ]
  },
  "artifact_verification": {
    "package_type": "cmake_install_tree",
    "build_command": "cmake --build <build-dir> --target sb_isql sb_admin sb_backup sb_security sb_verify sbdriver_conformance",
    "install_smoke": "ctest --test-dir <build-dir> -R cli_",
    "expected_outputs": [
      "bin/sb_isql",
      "bin/sb_admin",
      "bin/sb_backup",
      "bin/sb_security",
      "bin/sb_verify",
      "bin/sbdriver_conformance"
    ],
    "sbom": "release_gate_required",
    "signing": "release_gate_required",
    "license": "MPL-2.0"
  },
  "best_in_class_deltas": [
    {
      "comparator": "psql and isql command families",
      "delta": "interactive, batch, auth bootstrap, transaction execution, metadata shaping, and conformance manifest workflows",
      "proof": "cli lane CTest targets"
    },
    {
      "comparator": "psql and isql command families",
      "delta": "CLI retry and reconnect behavior never replays whole transactions or owns finality",
      "proof": "cli_txn_exec_parity_tests"
    }
  ],
  "dbeaver_exclusion": {
    "excluded_component_id": "adaptor:scratchbird-dbeaver-driver",
    "excluded_source_path": "project/drivers/adaptor/scratchbird-dbeaver-driver",
    "release_controller_status": "separate_controller_out_of_scope",
    "this_artifact_includes_dbeaver": false
  },
  "package_files": [
    "package_contract.json",
    "CMakeLists.txt",
    "README.md"
  ]
