    "sbwp_v1_1",
    "scratchbird_tls_1_3_floor",
    "engine_authentication_authority",
    "engine_authorization_authority",
    "mga_transaction_finality",
    "sys_information_metadata",
    "uuid_identity",
    "no_hidden_replay"
  ],
  "conformance": [
    "connect_auth",
    "prepare_execute_fetch",
    "transactions",
    "metadata",
    "type_mapping",
    "error_mapping",
    "reconnect",
    "protocol_negotiation",
    "cancellation"
  ],
  "delegation_posture": {
    "mode": "explicit_session",
    "target_component": "driver:cpp",
    "host_runtime": "native CLI tools",
    "authority_boundaries": [
