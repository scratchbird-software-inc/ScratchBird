{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScratchBird Charset Mapping Table",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "charset",
    "min_bytes",
    "max_bytes",
    "is_variable_width",
    "mappings"
  ],
  "properties": {
    "charset": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical charset name (matches charsets.json name)."
    },
    "description": {
      "type": "string"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "min_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "max_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "is_variable_width": {
      "type": "boolean"
    },
    "unmapped_policy": {
      "type": "string",
      "enum": ["reject", "replace"]
    },
    "replacement_codepoint": {
      "type": "string",
      "pattern": "^U\\+[0-9A-Fa-f]{4,8}$"
    },
    "invalid_sequences": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(0x[0-9A-Fa-f]{2})(\\s0x[0-9A-Fa-f]{2})*$"
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "single_byte_ranges": {
          "type": "array",
          "items": { "$ref": "#/$defs/byteRange" }
        },
        "lead_byte_ranges": {
          "type": "array",
          "items": { "$ref": "#/$defs/byteRange" }
        },
        "trail_byte_ranges": {
          "type": "array",
          "items": { "$ref": "#/$defs/byteRange" }
        },
        "multi_byte_sequences": {
          "type": "array",
          "items": { "$ref": "#/$defs/byteSequenceRange" }
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/mappingEntry" }
    }
  },
  "$defs": {
    "byteRange": {
      "type": "string",
      "pattern": "^0x[0-9A-Fa-f]{2}(-0x[0-9A-Fa-f]{2})?$"
    },
    "byteSequenceRange": {
      "type": "string",
      "pattern": "^(0x[0-9A-Fa-f]{2}(-0x[0-9A-Fa-f]{2})?)(\\s0x[0-9A-Fa-f]{2}(-0x[0-9A-Fa-f]{2})?)*$"
    },
    "mappingEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["byte_sequence", "unicode_codepoint"],
      "properties": {
        "byte_sequence": {
          "type": "string",
          "pattern": "^(0x[0-9A-Fa-f]{2})(\\s0x[0-9A-Fa-f]{2})*$",
          "description": "One or more bytes, space-separated, hex-prefixed."
        },
        "unicode_codepoint": {
          "type": "string",
          "pattern": "^U\\+[0-9A-Fa-f]{4,8}$"
        },
        "description": {
          "type": "string"
        }
      }
    }
  }
}
