# ScratchBird AI HTTP bridge example configuration

SCRATCHBIRD_AI_BRIDGE_HOST=127.0.0.1
SCRATCHBIRD_AI_BRIDGE_PORT=3095
SCRATCHBIRD_AI_BRIDGE_API_TOKEN=
SCRATCHBIRD_AI_BRIDGE_DIALECTS=native

# Use one default DSN for all enabled dialects...
SCRATCHBIRD_AI_BRIDGE_DEFAULT_DSN=scratchbird://user:password@127.0.0.1:3092/mydb

# ...or override per dialect:
# SCRATCHBIRD_AI_BRIDGE_DSN_NATIVE=scratchbird://user:password@127.0.0.1:3092/mydb

# Server setup profile: listener-only | managed | ipc-only | embedded
SCRATCHBIRD_AI_BRIDGE_SERVER_SETUP=listener-only

# Optional explicit transport/front-door overrides:
# SCRATCHBIRD_AI_BRIDGE_TRANSPORT_MODE=inet_listener
# SCRATCHBIRD_AI_BRIDGE_FRONT_DOOR_MODE=direct

# IPC-only/embedded setup options:
# SCRATCHBIRD_AI_BRIDGE_IPC_METHOD=unix
# SCRATCHBIRD_AI_BRIDGE_IPC_PATH=/tmp/scratchbird-main.sock
# Embedded mode is single-connection/non-shared; bridge enforces private scope.

# Managed setup options (required token for manager_proxy signon):
# SCRATCHBIRD_AI_BRIDGE_MANAGER_AUTH_TOKEN=
# SCRATCHBIRD_AI_BRIDGE_MANAGER_USERNAME=admin
# SCRATCHBIRD_AI_BRIDGE_MANAGER_DATABASE=mydb
# SCRATCHBIRD_AI_BRIDGE_MANAGER_CONNECTION_PROFILE=native_v3
# SCRATCHBIRD_AI_BRIDGE_MANAGER_CLIENT_INTENT=native_v3
# SCRATCHBIRD_AI_BRIDGE_MANAGER_CLIENT_FLAGS=0
# SCRATCHBIRD_AI_BRIDGE_MANAGER_AUTH_FAST_PATH=true

# Set when the Python driver is not installed but source exists in this checkout.
# SCRATCHBIRD_AI_BRIDGE_PYTHON_DRIVER_SRC=../../drivers/driver/python/src

# If enabled, compile probe failures return HTTP 400 instead of warnings.
SCRATCHBIRD_AI_BRIDGE_STRICT_COMPILE=0
