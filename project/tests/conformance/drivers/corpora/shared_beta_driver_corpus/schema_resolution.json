      ],
      "resolution_direction": "uuid_to_path",
      "request": {
        "uuid": "018f0a2b-0000-7000-9000-000000000302",
        "requesting_roles": [
          "report_reader"
        ],
        "driver_cached_path": "app.old_customer_name",
