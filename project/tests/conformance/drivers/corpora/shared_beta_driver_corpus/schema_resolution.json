{
  "corpus_id": "schema_resolution",
  "description": "Authorization-filtered UUID/path resolution fixtures shared by beta drivers and command-line tools.",
  "cases": [
    {
      "case_id": "BDRV-SCHEMA-001",
      "category": "authorization_filtered_uuid_path_resolution",
      "coverage": [
        "authorization_filtered_uuid_path_resolution",
        "sblr_uuid_server_revalidation"
      ],
      "resolution_direction": "path_to_uuid",
      "request": {
        "path": "app.customers",
        "visible_to_roles": [
          "report_reader"
        ]
      },
      "expected_result": {
        "uuid": "018f0a2b-0000-7000-9000-000000000101",
        "redacted_paths": []
      },
      "authorization_filter": "required",
      "server_revalidation": "required"
    },
    {
      "case_id": "BDRV-SCHEMA-002",
      "category": "authorization_filtered_uuid_path_resolution",
      "coverage": [
        "authorization_filtered_uuid_path_resolution"
      ],
      "resolution_direction": "path_to_uuid",
      "request": {
        "path": "app.payroll_private",
        "visible_to_roles": [
          "payroll_admin"
        ],
        "requesting_roles": [
          "report_reader"
        ]
      },
      "expected_refusal": {
        "diagnostic": "SB_AUTH_OBJECT_NOT_VISIBLE",
