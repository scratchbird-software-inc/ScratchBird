      },
      "authorization_filter": "required",
      "server_revalidation": "required"
    },
    {
      "case_id": "BDRV-SCHEMA-003",
      "category": "authorization_filtered_uuid_path_resolution",
      "coverage": [
        "authorization_filtered_uuid_path_resolution",
        "cache_lifecycle"
      ],
      "resolution_direction": "uuid_to_path",
      "request": {
        "uuid": "018f0a2b-0000-7000-9000-000000000301",
        "requesting_roles": [
          "report_reader"
        ],
        "driver_cached_path": "app.payroll_private"
      },
      "expected_refusal": {
        "diagnostic": "SB_AUTH_OBJECT_NOT_VISIBLE",
        "reason": "UUID to path resolution is authorization-filtered and may not reveal hidden object names"
