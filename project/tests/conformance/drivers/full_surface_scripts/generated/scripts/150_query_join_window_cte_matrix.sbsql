-- script_id: SBDFS-150
-- Generated query/join/window/CTE matrix over every datatype table.
CREATE TABLE __SB_NAMESPACE__.query_case_manifest (
    case_id VARCHAR(192) PRIMARY KEY,
    datatype_name VARCHAR(96) NOT NULL,
    operation_name VARCHAR(64) NOT NULL,
    statement_text TEXT NOT NULL
);

INSERT INTO __SB_NAMESPACE__.query_case_manifest VALUES
    ('QRY-null_type-point_lookup', 'null_type', 'point_lookup', 'SELECT * FROM __SB_NAMESPACE__.dt_null_type_values WHERE case_id = 1'),
    ('QRY-null_type-range_scan', 'null_type', 'range_scan', 'SELECT COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values WHERE case_id BETWEEN 10 AND 20'),
    ('QRY-null_type-null_scan', 'null_type', 'null_scan', 'SELECT COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values WHERE sample_value IS NULL'),
    ('QRY-null_type-self_inner_join', 'null_type', 'self_inner_join', 'SELECT COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values AS a INNER JOIN __SB_NAMESPACE__.dt_null_type_values AS b ON a.case_id = b.case_id'),
    ('QRY-null_type-self_left_join', 'null_type', 'self_left_join', 'SELECT COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values AS a LEFT JOIN __SB_NAMESPACE__.dt_null_type_values AS b ON a.case_id = b.case_id + 1'),
    ('QRY-null_type-exists_subquery', 'null_type', 'exists_subquery', 'SELECT COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values AS a WHERE EXISTS (SELECT 1 FROM __SB_NAMESPACE__.dt_null_type_values AS b WHERE b.case_id = a.case_id)'),
    ('QRY-null_type-group_by_value', 'null_type', 'group_by_value', 'SELECT sample_value, COUNT(*) FROM __SB_NAMESPACE__.dt_null_type_values GROUP BY sample_value'),
    ('QRY-null_type-window_by_id', 'null_type', 'window_by_id', 'SELECT case_id, ROW_NUMBER() OVER (ORDER BY case_id) AS rn FROM __SB_NAMESPACE__.dt_null_type_values'),
    ('QRY-null_type-recursive_cte', 'null_type', 'recursive_cte', 'WITH RECURSIVE seq(n) AS (VALUES (1) UNION ALL SELECT n + 1 FROM seq WHERE n < 16) SELECT COUNT(*) FROM seq'),
