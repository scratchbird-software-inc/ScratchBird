-- script_id: SBDFS-055
-- Purpose: generated expected-result fixture manifest for every driver-native built-in test lane.

CREATE TABLE __SB_NAMESPACE__.builtin_fixture_manifest (
    fixture_id VARCHAR(160) PRIMARY KEY,
