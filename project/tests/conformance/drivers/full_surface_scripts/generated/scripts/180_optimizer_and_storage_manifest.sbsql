-- script_id: SBDFS-180
-- Generated optimizer, page-size, and index readiness source manifest.
CREATE TABLE __SB_NAMESPACE__.optimizer_storage_source_manifest (
    source_path TEXT PRIMARY KEY,
    source_sha256 VARCHAR(64) NOT NULL,
    source_bytes INTEGER NOT NULL
);
CREATE TABLE __SB_NAMESPACE__.optimizer_page_index_matrix (
    case_id VARCHAR(160) PRIMARY KEY,
    page_size INTEGER NOT NULL,
    index_family VARCHAR(64) NOT NULL,
    statement_text TEXT NOT NULL
);

