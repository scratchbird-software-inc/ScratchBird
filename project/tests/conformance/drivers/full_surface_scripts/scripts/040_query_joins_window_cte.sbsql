-- script_id: SBDFS-040
-- Purpose: joins, set operations, grouping, windowing, recursive CTEs.

CREATE TABLE __SB_NAMESPACE__.query_customer (
    customer_id INTEGER PRIMARY KEY,
    region VARCHAR(16) NOT NULL,
    customer_name VARCHAR(64) NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.query_order (
    order_id INTEGER PRIMARY KEY,
    customer_id INTEGER NOT NULL,
    amount DECIMAL(18, 2) NOT NULL,
    order_status VARCHAR(16) NOT NULL
);

INSERT INTO __SB_NAMESPACE__.query_customer VALUES
    (1, 'east', 'Ada'),
    (2, 'east', 'Grace'),
    (3, 'west', 'Linus'),
    (4, 'north', 'Barbara');

INSERT INTO __SB_NAMESPACE__.query_order VALUES
    (101, 1, 10.00, 'open'),
    (102, 1, 15.00, 'closed'),
    (103, 2, 20.00, 'open'),
    (104, 3, 30.00, 'open');

SELECT 'SBDFS-040-001' AS assertion_id,
       COUNT(*) AS actual_count,
       4 AS expected_count
FROM __SB_NAMESPACE__.query_customer AS c
INNER JOIN __SB_NAMESPACE__.query_order AS o
    ON c.customer_id = o.customer_id;

SELECT 'SBDFS-040-002' AS assertion_id,
       COUNT(*) AS actual_count,
       1 AS expected_count
FROM __SB_NAMESPACE__.query_customer AS c
LEFT JOIN __SB_NAMESPACE__.query_order AS o
    ON c.customer_id = o.customer_id
WHERE o.order_id IS NULL;

SELECT 'SBDFS-040-003' AS assertion_id,
       COUNT(*) AS actual_count,
       3 AS expected_count
FROM __SB_NAMESPACE__.query_customer AS c
WHERE EXISTS (
    SELECT 1
    FROM __SB_NAMESPACE__.query_order AS o
    WHERE o.customer_id = c.customer_id
);

SELECT 'SBDFS-040-004' AS assertion_id,
       SUM(region_total) AS actual_total,
       75.00 AS expected_total
FROM (
    SELECT c.region, SUM(o.amount) AS region_total
    FROM __SB_NAMESPACE__.query_customer AS c
    JOIN __SB_NAMESPACE__.query_order AS o ON c.customer_id = o.customer_id
    GROUP BY c.region
    HAVING SUM(o.amount) >= 20.00
) AS grouped;

SELECT 'SBDFS-040-005' AS assertion_id,
       MAX(rn) AS actual_max_row_number,
       2 AS expected_max_row_number
FROM (
    SELECT c.region,
           o.order_id,
           ROW_NUMBER() OVER (PARTITION BY c.region ORDER BY o.amount DESC) AS rn
    FROM __SB_NAMESPACE__.query_customer AS c
    JOIN __SB_NAMESPACE__.query_order AS o ON c.customer_id = o.customer_id
) AS ranked;

WITH RECURSIVE seq(n) AS (
    VALUES (1)
    UNION ALL
    SELECT n + 1 FROM seq WHERE n < 10
)
SELECT 'SBDFS-040-006' AS assertion_id,
       SUM(n) AS actual_sum,
       55 AS expected_sum
FROM seq;

SELECT 'SBDFS-040-007' AS assertion_id,
       COUNT(*) AS actual_count,
       4 AS expected_count
FROM (
    SELECT customer_id FROM __SB_NAMESPACE__.query_customer
    UNION
    SELECT customer_id FROM __SB_NAMESPACE__.query_order
) AS unioned;
