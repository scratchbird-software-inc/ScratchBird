-- script_id: SBDFS-085
-- Purpose: recursive group, role, grant, deny, replay, and filtered-resolution security regression matrix.
-- namespace placeholder: __SB_NAMESPACE__

CREATE TABLE __SB_NAMESPACE__.security_subjects (
    subject_id VARCHAR(96) PRIMARY KEY,
    subject_kind VARCHAR(32) NOT NULL,
    active BOOLEAN NOT NULL,
    security_epoch INTEGER NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.security_memberships (
    membership_id VARCHAR(96) PRIMARY KEY,
    member_id VARCHAR(96) NOT NULL,
    member_kind VARCHAR(32) NOT NULL,
    parent_id VARCHAR(96) NOT NULL,
    parent_kind VARCHAR(32) NOT NULL,
    active BOOLEAN NOT NULL,
    security_epoch INTEGER NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.security_grants (
    grant_id VARCHAR(96) PRIMARY KEY,
    subject_id VARCHAR(96) NOT NULL,
    subject_kind VARCHAR(32) NOT NULL,
    target_id VARCHAR(96) NOT NULL,
    right_name VARCHAR(32) NOT NULL,
    deny BOOLEAN NOT NULL,
    active BOOLEAN NOT NULL,
    security_epoch INTEGER NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.security_authorization_cases (
    case_id VARCHAR(96) PRIMARY KEY,
    principal_id VARCHAR(96) NOT NULL,
    target_id VARCHAR(96) NOT NULL,
    right_name VARCHAR(32) NOT NULL,
    expected_decision VARCHAR(32) NOT NULL,
    expected_reason VARCHAR(96) NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.security_sblr_replay_cases (
    case_id VARCHAR(96) PRIMARY KEY,
    original_principal_id VARCHAR(96) NOT NULL,
    replay_principal_id VARCHAR(96) NOT NULL,
    target_id VARCHAR(96) NOT NULL,
    right_name VARCHAR(32) NOT NULL,
    expected_refusal VARCHAR(96) NOT NULL
);

CREATE TABLE __SB_NAMESPACE__.security_uuid_resolution_cases (
    case_id VARCHAR(96) PRIMARY KEY,
    principal_id VARCHAR(96) NOT NULL,
    object_uuid VARCHAR(96) NOT NULL,
    expected_visible BOOLEAN NOT NULL,
    expected_diagnostic VARCHAR(96)
);

WITH RECURSIVE depth_probe(depth_value) AS (
    VALUES (0)
    UNION ALL
    SELECT depth_value + 1
    FROM depth_probe
    WHERE depth_value < 127
)
INSERT INTO __SB_NAMESPACE__.security_subjects
SELECT 'grp_depth_' || CAST(depth_value AS VARCHAR(16)),
       'group',
       TRUE,
       11
FROM depth_probe;

INSERT INTO __SB_NAMESPACE__.security_subjects VALUES
    ('user_direct', 'principal', TRUE, 11),
    ('user_nested', 'principal', TRUE, 11),
    ('user_role_nested', 'principal', TRUE, 11),
    ('user_denied', 'principal', TRUE, 11),
    ('user_none', 'principal', TRUE, 11),
    ('user_stale', 'principal', TRUE, 11),
    ('user_cycle', 'principal', TRUE, 11),
    ('role_reporting', 'role', TRUE, 11),
    ('role_security_reader', 'role', TRUE, 11),
    ('grp_cycle_a', 'group', TRUE, 11),
    ('grp_cycle_b', 'group', TRUE, 11),
    ('grp_stale_parent', 'group', TRUE, 11);

WITH RECURSIVE depth_edges(depth_value) AS (
    VALUES (0)
    UNION ALL
    SELECT depth_value + 1
    FROM depth_edges
    WHERE depth_value < 127
)
INSERT INTO __SB_NAMESPACE__.security_memberships
SELECT 'm_depth_' || CAST(depth_value AS VARCHAR(16)),
       CASE WHEN depth_value = 0
            THEN 'user_nested'
            ELSE 'grp_depth_' || CAST(depth_value - 1 AS VARCHAR(16))
       END,
       CASE WHEN depth_value = 0 THEN 'principal' ELSE 'group' END,
       'grp_depth_' || CAST(depth_value AS VARCHAR(16)),
       'group',
       TRUE,
       11
FROM depth_edges;

INSERT INTO __SB_NAMESPACE__.security_memberships VALUES
    ('m_role_user', 'user_role_nested', 'principal', 'grp_depth_0', 'group', TRUE, 11),
    ('m_role_chain', 'grp_depth_127', 'group', 'role_reporting', 'role', TRUE, 11),
    ('m_denied_user', 'user_denied', 'principal', 'grp_depth_0', 'group', TRUE, 11),
    ('m_stale_user', 'user_stale', 'principal', 'grp_stale_parent', 'group', TRUE, 10),
    ('m_cycle_user', 'user_cycle', 'principal', 'grp_cycle_a', 'group', TRUE, 11),
    ('m_cycle_ab', 'grp_cycle_a', 'group', 'grp_cycle_b', 'group', TRUE, 11),
    ('m_cycle_ba', 'grp_cycle_b', 'group', 'grp_cycle_a', 'group', TRUE, 11);

INSERT INTO __SB_NAMESPACE__.security_grants VALUES
    ('grant_direct_select', 'user_direct', 'principal', 'object_direct', 'SELECT', FALSE, TRUE, 11),
    ('grant_top_group_select', 'grp_depth_127', 'group', 'object_nested', 'SELECT', FALSE, TRUE, 11),
    ('grant_role_update', 'role_reporting', 'role', 'object_role', 'UPDATE', FALSE, TRUE, 11),
    ('grant_denied_allow', 'grp_depth_127', 'group', 'object_denied', 'SELECT', FALSE, TRUE, 11),
    ('grant_denied_direct', 'user_denied', 'principal', 'object_denied', 'SELECT', TRUE, TRUE, 11),
    ('grant_security_reader', 'role_security_reader', 'role', 'object_security_catalog', 'VISIBLE', FALSE, TRUE, 11);

INSERT INTO __SB_NAMESPACE__.security_authorization_cases VALUES
    ('case_direct_user_grant', 'user_direct', 'object_direct', 'SELECT', 'allow', 'direct_principal_grant'),
    ('case_nested_group_128', 'user_nested', 'object_nested', 'SELECT', 'allow', 'recursive_group_grant_depth_128'),
    ('case_role_via_group', 'user_role_nested', 'object_role', 'UPDATE', 'allow', 'role_grant_inherited_through_group'),
    ('case_target_specific_denied', 'user_nested', 'object_direct', 'SELECT', 'deny', 'target_specific_grant_required'),
    ('case_no_grant_denied', 'user_none', 'object_nested', 'SELECT', 'deny', 'no_effective_grant'),
    ('case_direct_deny_wins', 'user_denied', 'object_denied', 'SELECT', 'deny', 'explicit_deny_precedence'),
    ('case_stale_epoch_refused', 'user_stale', 'object_nested', 'SELECT', 'refuse', 'security_epoch_mismatch'),
    ('case_cycle_refused', 'user_cycle', 'object_nested', 'SELECT', 'refuse', 'membership_cycle');

