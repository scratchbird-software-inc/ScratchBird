    ('case_visible_uuid_path', 'user_nested', 'object_nested', TRUE, NULL),
    ('case_hidden_uuid_path', 'user_none', 'object_nested', FALSE, 'SB_AUTH_OBJECT_NOT_VISIBLE'),
    ('case_security_catalog_filtered', 'user_direct', 'object_security_catalog', FALSE, 'SB_AUTH_OBJECT_NOT_VISIBLE');

SELECT 'SBDFS-085-001' AS assertion_id,
       COUNT(*) AS actual_subject_rows,
       140 AS expected_subject_rows
FROM __SB_NAMESPACE__.security_subjects;

SELECT 'SBDFS-085-002' AS assertion_id,
       MAX(depth_value) AS actual_max_recursive_depth,
       128 AS expected_max_recursive_depth
FROM (
    WITH RECURSIVE depth_probe(depth_value) AS (
        VALUES (0)
        UNION ALL
        SELECT depth_value + 1
        FROM depth_probe
        WHERE depth_value < 128
    )
    SELECT depth_value FROM depth_probe
) AS depth_check;

SELECT 'SBDFS-085-003' AS assertion_id,
       COUNT(*) AS actual_nested_memberships,
       135 AS expected_nested_memberships
FROM __SB_NAMESPACE__.security_memberships;

SELECT 'SBDFS-085-004' AS assertion_id,
       COUNT(*) AS actual_authorization_cases,
       8 AS expected_authorization_cases
FROM __SB_NAMESPACE__.security_authorization_cases;

SELECT 'SBDFS-085-005' AS assertion_id,
       COUNT(*) AS actual_allowed_cases,
       3 AS expected_allowed_cases
FROM __SB_NAMESPACE__.security_authorization_cases
WHERE expected_decision = 'allow';

SELECT 'SBDFS-085-006' AS assertion_id,
       COUNT(*) AS actual_denied_or_refused_cases,
       5 AS expected_denied_or_refused_cases
FROM __SB_NAMESPACE__.security_authorization_cases
WHERE expected_decision IN ('deny', 'refuse');

SELECT 'SBDFS-085-007' AS assertion_id,
       COUNT(*) AS actual_replay_refusal_cases,
       2 AS expected_replay_refusal_cases
FROM __SB_NAMESPACE__.security_sblr_replay_cases
WHERE expected_refusal = 'SECURITY.AUTHORIZATION.PRINCIPAL_MISMATCH';

SELECT 'SBDFS-085-008' AS assertion_id,
       COUNT(*) AS actual_hidden_uuid_cases,
       2 AS expected_hidden_uuid_cases
FROM __SB_NAMESPACE__.security_uuid_resolution_cases
WHERE expected_visible = FALSE;

SELECT 'SBDFS-085-009' AS assertion_id,
       COUNT(*) AS actual_epoch_or_cycle_refusals,
       2 AS expected_epoch_or_cycle_refusals
FROM __SB_NAMESPACE__.security_authorization_cases
WHERE expected_reason IN ('security_epoch_mismatch', 'membership_cycle');

SELECT 'SBDFS-085-010' AS assertion_id,
       COUNT(*) AS actual_security_matrix_cases,
       13 AS expected_security_matrix_cases
FROM (
    SELECT case_id FROM __SB_NAMESPACE__.security_authorization_cases
    UNION ALL
    SELECT case_id FROM __SB_NAMESPACE__.security_sblr_replay_cases
    UNION ALL
    SELECT case_id FROM __SB_NAMESPACE__.security_uuid_resolution_cases
) AS security_case_union;
