SELECT 'SBDFS-020-001' AS assertion_id,
       COUNT(*) AS actual_count,
       4 AS expected_count
FROM __SB_NAMESPACE__.dml_accounts;

SELECT 'SBDFS-020-002' AS assertion_id,
       CAST(SUM(balance) AS DECIMAL(18,2)) AS actual_balance,
       CAST(1251.00 AS DECIMAL(18,2)) AS expected_balance
FROM __SB_NAMESPACE__.dml_accounts;

SELECT 'SBDFS-020-003' AS assertion_id,
       owner_name AS actual_owner,
       'Grace Updated' AS expected_owner
FROM __SB_NAMESPACE__.dml_accounts
WHERE account_id = 2;
