INSERT INTO __SB_NAMESPACE__.datatype_matrix (id) VALUES (3);

SELECT 'SBDFS-010-001' AS assertion_id,
       COUNT(*) AS actual_count,
       3 AS expected_count
FROM __SB_NAMESPACE__.datatype_matrix;

SELECT 'SBDFS-010-002' AS assertion_id,
       COUNT(*) AS actual_null_rows,
       1 AS expected_null_rows
FROM __SB_NAMESPACE__.datatype_matrix
WHERE bool_col IS NULL
  AND integer_col IS NULL
  AND text_col IS NULL
  AND uuid_col IS NULL;

SELECT 'SBDFS-010-003' AS assertion_id,
       CAST(integer_col AS BIGINT) + CAST(smallint_col AS BIGINT) AS actual_cast_sum,
       -2147516416 AS expected_cast_sum
FROM __SB_NAMESPACE__.datatype_matrix
WHERE id = 1;
