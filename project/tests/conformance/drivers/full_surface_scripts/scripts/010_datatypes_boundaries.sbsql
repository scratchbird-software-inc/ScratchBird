    3.5, 9.25, 'charmax', 'varchar-max',
    'text maximum path', X'fffefdfcfbfa',
    DATE '9999-12-31', TIME '23:59:59',
    TIMESTAMP '9999-12-31 23:59:59',
    TIMESTAMPTZ '9999-12-31 23:59:59+00:00',
