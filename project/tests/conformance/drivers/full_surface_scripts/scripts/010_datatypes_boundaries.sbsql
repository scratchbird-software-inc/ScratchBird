-- script_id: SBDFS-010
-- Purpose: table/column/type boundary coverage.

CREATE TABLE __SB_NAMESPACE__.datatype_matrix (
    id INTEGER PRIMARY KEY,
    bool_col BOOLEAN,
    smallint_col SMALLINT,
    integer_col INTEGER,
    bigint_col BIGINT,
    int128_col INT128,
    decimal_col DECIMAL(38, 10),
    numeric_col NUMERIC(38, 10),
    real_col REAL,
    double_col DOUBLE PRECISION,
    char_col CHAR(8),
    varchar_col VARCHAR(128),
    text_col TEXT,
    blob_col BLOB,
    date_col DATE,
    time_col TIME,
    timestamp_col TIMESTAMP,
    timestamptz_col TIMESTAMPTZ,
    interval_col INTERVAL,
    uuid_col UUID,
    json_col JSON,
    xml_col XML,
    vector_col VECTOR(3),
    array_col ARRAY<INTEGER>
);

INSERT INTO __SB_NAMESPACE__.datatype_matrix (
    id, bool_col, smallint_col, integer_col, bigint_col, int128_col,
    decimal_col, numeric_col, real_col, double_col, char_col, varchar_col,
    text_col, blob_col, date_col, time_col, timestamp_col, timestamptz_col,
    interval_col, uuid_col, json_col, xml_col, vector_col, array_col
) VALUES (
    1, TRUE, -32768, -2147483648, -9223372036854775808,
    -170141183460469231731687303715884105728,
    -9999999999999999999999999999.9999999999,
    -12345678901234567890.1234567890,
    -3.5, -9.25, 'charmin', 'varchar-min',
    'text minimum path', X'000102030405',
    DATE '0001-01-01', TIME '00:00:00',
    TIMESTAMP '0001-01-01 00:00:00',
    TIMESTAMPTZ '0001-01-01 00:00:00+00:00',
    INTERVAL 'P1D',
    UUID '018f0a2b-0000-7000-9000-000000000001',
    JSON '{"kind":"min","n":1}',
    XML '<root kind="min"/>',
    VECTOR '[0,0,0]',
    ARRAY[1,2,3]
);

